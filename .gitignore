# Scientific data (keep legal signatures)
# Exclude large data files but keep essential exports
*.npy
*.csv
*.h5
*.hdf5

# UE5 exports (keep essential files)
# Large mesh files can be regenerated
*.fbx
*.blend
*.max

# Documentation builds
docs/_build/
site/

# Jupyter Notebook
.ipynb_checkpoints

# Supervisor logs (keep essential logs only)
/var/log/supervisor/*.log

# Keep essential legal and configuration files
!legal_signatures.json
!phase26_completion_report.md
!phase26_upgrade_plan.md
!system_audit_report.md
!README.md
!LICENSE
.env
backend/.env
**/.env
